{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "lib": ["ES2022"],
        "moduleResolution": "bundler",
        "strict": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "noEmit": true,
        "skipLibCheck": true,
        "types": ["@webgpu/types", "node"],
        "rootDir": "./src"
    },
    "include": ["./src"]
}
